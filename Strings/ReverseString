package dsa.string;

import java.util.Arrays;

public class ReverseString {
	public static void main(String[] args) {
		char[] s = {'h','e','l','l','o','e','f'};
		int start = 0;
		int end = s.length-1;
		
		while(end>start) {
			char temp = s[start];
			s[start] = s[end];
			s[end] = temp;
			start++;
			end--;
		}
		System.out.println(Arrays.toString(s));
	}
}
